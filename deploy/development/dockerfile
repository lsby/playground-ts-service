# ====================
# 构建阶段
# ====================
FROM node:22 AS builder

ARG NPM_REGISTRY=https://registry.npmjs.org
ARG PRISMA_ENGINES_MIRROR=
ARG ELECTRON_MIRROR=

ENV TZ=Asia/Shanghai
ENV PRISMA_ENGINES_MIRROR=${PRISMA_ENGINES_MIRROR}
ENV ELECTRON_MIRROR=${ELECTRON_MIRROR}

WORKDIR /opt/app

# 先拷贝依赖文件以利用 Docker 缓存
COPY package.json pnpm-lock.yaml ./

# 配置分层镜像并安装依赖
RUN corepack enable && \
    pnpm config set registry ${NPM_REGISTRY} && \
    pnpm config set @lsby:registry https://registry.npmjs.org && \
    pnpm install --ignore-scripts

# 拷贝剩余源码
COPY . .

# 执行构建脚本
ARG SKIP_BUILD=false
RUN if [ "$SKIP_BUILD" != "true" ]; then \
      export PARCEL_WORKER_BACKEND=process && \
      npm run _build:all; \
    else \
      echo "Skipping build, using pre-built dist folder."; \
    fi

# 初始化默认数据库
RUN echo "\n" | npm run db:push:dev:web

# ====================
# 安装阶段
# ====================
FROM node:22 AS installer
ARG NPM_REGISTRY=https://registry.npmjs.org

ENV TZ=Asia/Shanghai
WORKDIR /opt/app

# 从构建阶段拷贝依赖文件
COPY --from=builder /opt/app/package.json /opt/app/
COPY --from=builder /opt/app/pnpm-lock.yaml /opt/app/

# 安装依赖
RUN corepack enable && \
    pnpm config set registry ${NPM_REGISTRY} && \
    pnpm config set @lsby:registry https://registry.npmjs.org && \
    pnpm install --ignore-scripts

# ====================
# 运行阶段
# ====================
FROM node:22-slim

ENV TZ=Asia/Shanghai
WORKDIR /opt/app

COPY --from=installer /opt/app/node_modules /opt/app/node_modules
COPY --from=builder /opt/app/db/dev-web.db /opt/app/db-default-dev-web.db
COPY --from=builder /opt/app/package.json /opt/app/
COPY --from=builder /opt/app/tsconfig.json /opt/app/
COPY --from=builder /opt/app/src /opt/app/src
COPY --from=builder /opt/app/prisma /opt/app/prisma
COPY --from=builder /opt/app/prisma.config.ts /opt/app/prisma.config.ts
COPY --from=builder /opt/app/dist/src/web /opt/app/dist/src/web
COPY --from=builder /opt/app/public /opt/app/public
COPY --from=builder /opt/app/.env/.env.development-web /opt/app/.env/.env.development-web

EXPOSE 3000

CMD ["sh", "-c", "mkdir -p /opt/app/db; if [ ! -f /opt/app/db/dev-web.db ]; then echo 'Initializing database from default'; cp /opt/app/db-default-dev-web.db /opt/app/db/dev-web.db; else echo 'Database already exists'; fi; npx dotenv -e ./.env/.env.development-web -- prisma migrate deploy && npm run run:service:dev"]
